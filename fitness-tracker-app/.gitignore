# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files (NEVER COMMIT THESE!)
.env*.local
.env

# Google Services (NEVER COMMIT THESE!)
google-services.json
GoogleService-Info.plist

# typescript
*.tsbuildinfo

# Other
kiro/

# Android - ignore sensitive files and build artifacts
android/app/src/main/AndroidManifest.xml
android/output.log
android/.gradle/
android/app/build/
android/build/
android/local.properties
