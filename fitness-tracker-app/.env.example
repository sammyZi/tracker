# Google Maps API Key
# Get this from: Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Native Android builds use this key (injected via gradle manifestPlaceholders)
# Should be the same value as EXPO_PUBLIC_GOOGLE_MAPS_API_KEY
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase Configuration
# Get these from: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=your-supabase-project-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# EAS Project ID (optional, for EAS Build)
# Get this from: expo.dev → your project → Project ID
EAS_PROJECT_ID=your-eas-project-id
