<?xml version="1.0" encoding="utf-8"?>
<!--
  Data Extraction Rules for Android 12+ (API 31+)

  Ensures that local data is NOT backed up to Google Drive, so when the
  app is uninstalled and reinstalled, it starts fresh.

  This prevents the bug where AsyncStorage data persists across
  uninstall/reinstall cycles via Android Auto Backup.
-->
<data-extraction-rules>
  <!-- Cloud backup: exclude everything -->
  <cloud-backup>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
  </cloud-backup>

  <!-- Device-to-device transfer: exclude everything -->
  <device-transfer>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
    <exclude domain="root" path="." />
  </device-transfer>
</data-extraction-rules>
